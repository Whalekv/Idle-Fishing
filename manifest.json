{
  "manifest_version": 3,
  "name": "Happy Fishing",
  "description": "钓鱼游戏",
  "version": "1.0",
  "action": { "default_popup": "popup/popup.html" },
  "icons": { "48": "assets/icon.png" },
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background/bg.js" },

  "options_page": "fishpond/fishpond.html",

  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": [
      "content/success/success.js",
      "content/game/config.js",       
      "content/game/fish.js",
      "content/game/core.js",
      "content/game/ui.js",
      "content/game/sync.js"
    ],
    "run_at": "document_end",
    "all_frames": false
  }],

  "web_accessible_resources": [{
    "resources": [
      "content/overlay.js",
      "i18n.js",
      "i18n-data.js",
      "assets/pond.svg", 
      "assets/fishingFloat.svg",
      "fishpond/fishpond.js",
      "config.js"
    ],
    "matches": ["<all_urls>"]
  }]
}