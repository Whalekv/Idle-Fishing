{
  "manifest_version": 3,
  "name": "Happy Fishing",
  "description": "钓鱼游戏",
  "version": "1.0",
  "action": { "default_popup": "popup.html" },
  "icons": { "48": "icon.png" },
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "bg.js" },

  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["success.js","sync.js"],
    "run_at": "document_end",
    "all_frames": false
  }],

  "web_accessible_resources": [{
    "resources": ["overlay.js","pond.svg", "fishingFloat.svg"],
    "matches": ["<all_urls>"]
  }]
}